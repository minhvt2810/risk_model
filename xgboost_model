# gán lại good/bad
data_model$tag_gb[data_model$tag_gb=="GOOD"] <- 0
data_model$tag_gb[data_model$tag_gb=="BAD"] <- 1

##chia tập dữ liệu THEO OOT
dev_data <- sqldf("select *
                   from data_model where snapshot_date<'20230930'
                   ")

test_data <- sqldf("select *
                   from data_model where snapshot_date>='20230930'
                   and snapshot_date<'20240930'
                   ")

val_data <- sqldf("select  *
                 from data_model where snapshot_date >='20240930'
                  ")

#bỏ snapshot_Date
dev_data <- dev_data %>% select(everything(),-snapshot_date,-customer_id)
test_data <- test_data %>% select(everything(),-snapshot_date,-customer_id)
val_data <- val_data %>% select(everything(),-snapshot_date,-customer_id)


## tính IV+ LỌC concentration+lọc IV
bins <- woebin(dev_data, y = "tag_gb"
               ,bin_num_limit=10, positive = "bad|0"
               , method = "tree"
               ,count_distr_limit=0.01
               ,stop_limit=0.01)

# lapply(list_df, function(df) { nrow(df) })

list_var <- data.frame()

for (i in bins) {
  x <- data.frame(i)
  list_var <- rbind(x,list_var)
}

list_var <- list_var %>%
  select(everything(),-breaks,-is_special_values) %>% 
  mutate(bad_rate = neg/count) %>%
  group_by(variable) %>%
  mutate(max_dis =max(count_distr)) %>%
  ungroup() %>%
  filter(total_iv >= 0.1 & max_dis<0.9) # lấy các biến có iv>=10% và mức độ tập trung data <90%

# lọc correlation
name_var <- unique(list_var$variable)

var_cor <- dev_data %>% select(all_of(name_var)) %>% cor()

to_drop <- findCorrelation(var_cor, cutoff = 0.85, names = TRUE, exact = TRUE)# Chọn biến nên loại với ngưỡng |r| > 0.85

# chia du lieu
x_train <- subset(dev_data %>% select(-all_of(to_drop),-total_ost,-max_dpd,-mob), select = -c(tag_gb))
y_train <- dev_data$tag_gb

x_test <- subset(test_data %>% select(-all_of(to_drop),-total_ost,-max_dpd,-mob), select = -c(tag_gb))
y_test <- test_data$tag_gb

x_val <- subset(val_data %>% select(-all_of(to_drop),-total_ost,-max_dpd,-mob), select = -c(tag_gb))
y_val <- val_data$tag_gb
# Tạo DMatrix
dtrain <- xgb.DMatrix(data = as.matrix(x_train), label = y_train)
dtest  <- xgb.DMatrix(data = as.matrix(x_test),  label = y_test)
dval  <- xgb.DMatrix(data = as.matrix(x_val),  label = y_val)
# names(x_train)
# tham số ban đầu

params_bin <- list(
  objective        = "binary:logistic",
  eval_metric      = "auc",
  max_depth        = 3,
  eta              = 0.1,        # learning rate
  subsample        = 0.8,
  colsample_bytree = 0.8,
  min_child_weight = 1
)

## trainning
# c1: chạy theo early_stopping_rounds
watchlist <- list(train = dtrain, eval = dtest)

set.seed(2026)
model_bin <- xgb.train(
  params = params_bin,
  data = dtrain,
  nrounds = 500,
  watchlist = watchlist,
  early_stopping_rounds = 30,
  print_every_n = 20
)

model_bin$best_iteration
model_bin$best_score
model_bin$evaluation_log
model_bin$best_ntreelimit

#importance các biến train full model
imp <- xgb.importance(feature_names = colnames(x_train), model = model_bin)
xgb.plot.importance(imp)

#importance các biến lũy kế đến vòng tối ưu
best_iter <- model_bin$best_iteration
num_class <- ifelse(is.null(model_bin$params$num_class), 1, model_bin$params$num_class)

max_tree <- best_iter * num_class - 1

dt <- xgb.model.dt.tree(model = model_bin)


dt_best <- dt %>%
  dplyr::filter(Tree <= max_tree, Feature != "Leaf")


importance_best <- dt_best %>%
  dplyr::group_by(Feature) %>%
  dplyr::summarise(
    quality  = sum(Quality),
    cover = sum(Cover),
    freq  = dplyr::n(),     # số lần feature được chọn để split
    .groups = "drop"
  ) %>%
  dplyr::arrange(desc(quality))   # Gain là thước đo chính


ggplot(importance_best, aes(x = reorder(Feature, quality), ## VẼ importance
                     y = quality)) +
  geom_col(fill = "steelblue") +
  coord_flip() +
  labs(
    title = paste("Feature Importance tại Best Iteration =", model_bin$best_iteration),
    x = "Feature",
    y = "quality"
  ) +
  theme_minimal(base_size = 14)
