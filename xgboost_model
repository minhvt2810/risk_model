result_train <- data.frame(
  actual = y_train,
  predict = pd_train) %>% arrange(predict)

result_test <- data.frame(
  actual = y_test,
  predict = pd_test) %>% arrange(predict)


cut_off <- quantile(result_train$predict,0.8,na.rm=TRUE)###cutoff tập train

result_val <- data.frame(
  actual = y_val,
  pd = pd_val,
  predict = case_when(pd_val >=cut_off ~ 1,TRUE ~ 0)
) %>% arrange(pd)

hieu_qua <- data.frame(precision = Precision(y_pred = result_val$predict, y_true = result_val$actual, positive = "1")
                       ,recall = Recall(y_pred = result_val$predict,y_true = result_val$actual, positive = "1")
                       ,f1_score = F1_Score(y_pred = result_val$predict, y_true = result_val$actual, positive = "1")
                       )
# quy ra score TẬP TRAIN

pdo <- 50
base_score <- 600
factor <- pdo/log(2)
odd <- 20
offset <- base_score - factor*log(odd)

result_train_score <- result_train %>% 
  mutate(odds = (1-predict)/predict
         ,score_cali = round(offset + factor*log(odds),0)
          ,bin = ntile(score_cali, 10))

binning_train <- result_train_score %>% group_by(bin) %>%
  summarise(max_bin = max(score_cali)
            ,min_bin = min(score_cali)
            ,cnt_obs_train = n()) %>%
  mutate(pct_obs_train = cnt_obs_train/sum(cnt_obs_train))

# tính PSI
result_test_score <- result_test %>% ## tính %obs tập test
  mutate(odds = (1-predict)/predict
         ,score_cali = round(offset + factor*log(odds),0)
         ,bin = case_when(score_cali <= binning_train$max_bin[binning_train$bin == 1] ~ 1
                    ,score_cali >binning_train$min_bin[binning_train$bin == 2] & score_cali<=binning_train$max_bin[binning_train$bin == 2] ~ 2
                    ,score_cali >binning_train$min_bin[binning_train$bin == 3] & score_cali<=binning_train$max_bin[binning_train$bin == 3] ~ 3
                    ,score_cali >binning_train$min_bin[binning_train$bin == 4] & score_cali<=binning_train$max_bin[binning_train$bin == 4] ~ 4
                    ,score_cali >binning_train$min_bin[binning_train$bin == 5] & score_cali<=binning_train$max_bin[binning_train$bin == 5] ~ 5
                    ,score_cali >binning_train$min_bin[binning_train$bin == 6] & score_cali<=binning_train$max_bin[binning_train$bin == 6] ~ 6
                    ,score_cali >binning_train$min_bin[binning_train$bin == 7] & score_cali<=binning_train$max_bin[binning_train$bin == 7] ~ 7
                    ,score_cali >binning_train$min_bin[binning_train$bin == 8] & score_cali<=binning_train$max_bin[binning_train$bin == 8] ~ 8
                    ,score_cali >binning_train$min_bin[binning_train$bin == 9] & score_cali<=binning_train$max_bin[binning_train$bin == 9] ~ 9
                    ,score_cali >binning_train$min_bin[binning_train$bin == 10] ~ 10
                    )
         ) %>%
  group_by(bin) %>%
  summarise(cnt_obs_test = n()
            ) %>%
  mutate(pct_obs_test = cnt_obs_test/sum(cnt_obs_test))


result_val_score <- result_val %>% ## tính %obs tập train
  mutate(odds = (1-pd)/pd
         ,score_cali = round(offset + factor*log(odds),0)
         ,bin = case_when(score_cali <= binning_train$max_bin[binning_train$bin == 1] ~ 1
                          ,score_cali >binning_train$min_bin[binning_train$bin == 2] & score_cali<=binning_train$max_bin[binning_train$bin == 2] ~ 2
                          ,score_cali >binning_train$min_bin[binning_train$bin == 3] & score_cali<=binning_train$max_bin[binning_train$bin == 3] ~ 3
                          ,score_cali >binning_train$min_bin[binning_train$bin == 4] & score_cali<=binning_train$max_bin[binning_train$bin == 4] ~ 4
                          ,score_cali >binning_train$min_bin[binning_train$bin == 5] & score_cali<=binning_train$max_bin[binning_train$bin == 5] ~ 5
                          ,score_cali >binning_train$min_bin[binning_train$bin == 6] & score_cali<=binning_train$max_bin[binning_train$bin == 6] ~ 6
                          ,score_cali >binning_train$min_bin[binning_train$bin == 7] & score_cali<=binning_train$max_bin[binning_train$bin == 7] ~ 7
                          ,score_cali >binning_train$min_bin[binning_train$bin == 8] & score_cali<=binning_train$max_bin[binning_train$bin == 8] ~ 8
                          ,score_cali >binning_train$min_bin[binning_train$bin == 9] & score_cali<=binning_train$max_bin[binning_train$bin == 9] ~ 9
                          ,score_cali >binning_train$min_bin[binning_train$bin == 10] ~ 10
         )
  ) %>%
  group_by(bin) %>%
  summarise(cnt_obs_val = n()) %>%
  mutate(pct_obs_val = cnt_obs_val/sum(cnt_obs_val))


psi_model <- binning_train %>% 
  left_join(result_test_score,by = c("bin"="bin")) %>% 
  left_join(result_val_score,by = c("bin"="bin")) %>%
  mutate(psi_component_train_test = round((pct_obs_train-pct_obs_test)*log(pct_obs_train/pct_obs_test),2)
         ,psi_component_train_val = round((pct_obs_train-pct_obs_val)*log(pct_obs_train/pct_obs_val),2)
         ,psi_sum_train_test = sum(psi_component_train_test)
         ,psi_sum_train_val = sum(psi_component_train_val)
         )

